; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="New Game Project"
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

Stats="*res://scenes/ui/stats/global_stats.gd"
SaveManager="*res://scripts/core/save_manager.gd"
DialogueManager="*res://scripts/ui/dialogue_manager.gd"
SceneTransition="*res://scenes/core/scene_transition.tscn"
UIPolish="*res://scripts/core/ui_polish.gd"
SignalBus="*res://scripts/core/signal_bus.gd"
GameManager="*res://scripts/core/game_manager.gd"
SwarmManager="*res://scripts/core/swarm_manager.gd"
LevelManager="*res://scripts/core/level_manager.gd"
AudioManager="*res://scripts/core/audio_manager.gd"
Global="*res://scripts/core/global.gd"
GlobalSettings="*res://scripts/core/global_settings.gd"

[display]

window/size/window_width_override=960
window/size/window_height_override=540
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[gui]

theme/custom="res://global_theme.tres"

[layer_names]

2d_physics/layer_1="Environment"
2d_physics/layer_2="Player"
2d_physics/layer_3="Enemy"
2d_physics/layer_4="Interactable"
2d_physics/layer_5="Hazard"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

textures/canvas_textures/default_texture_filter=0
rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
